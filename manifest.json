{
  "manifest_version": 3,
  "name": "Keep Focus",
  "version": "1.0.0",
  "description": "Block distracting websites with intentional friction. Build better focus habits, one decision at a time.",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "favicon"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "dist/scripts/background.js"
  },
  "action": {
    "default_popup": "pages/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "96": "icons/icon96.png",
      "128": "icons/icon128.png",
      "256": "icons/icon256.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/scripts/content.js"],
      "type": "module",
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png",
    "256": "icons/icon256.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "dist/content/*.js",
        "dist/utils/*.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}

